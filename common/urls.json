{
  "version": 2,
  "server_url": "https://aimaxx.organisationapp.online",
  "api_base_path": "/api/",
  "ws_base_path": "/api/ws/",
  "auth": {
    "rest_headers": ["X-API-Key", "X-Device-Identifier", "X-Workspace-Id"],
    "ws_query": ["api_key", "device_hash", "workspace_id"]
  },
  "rest": {
    "health": { "method": "GET", "path": "health/", "auth": "none" },
    "devices_register": { "method": "POST", "path": "devices/register/", "auth": "api_key" },
    "devices_identifier": { "method": "POST", "path": "devices/identifier/", "auth": "api_key" },
    "exposed_routes_tree": { "method": "GET", "path": "exposed_routes_tree/", "auth": "device" },
    "workspace_open": { "method": "POST", "path": "workspaces/", "auth": "device" },
    "workspace_tree": { "method": "GET", "path": "workspaces/{workspace_id}/tree/", "auth": "workspace" }
  },
  "websocket": {
    "watchdog": { "path": "watchdog/" },
    "ide_search": { "path": "ide_search/" },
    "getbypath": { "path": "getbypath/" },
    "git": { "path": "git/" },
    "agent": { "path": "agent/" }
  }
}
