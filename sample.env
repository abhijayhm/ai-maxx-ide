# ai-maxx-ide environment template
# Copy to .env at the repo root:  copy sample.env .env
# Used by: scripts/windows/setup_cloudflare_tunnel.* and server/ (later)

# --- Cloudflare tunnel (setup script reads these directly) ---

# Public HTTPS hostname for the Django API + WebSockets (tunnel ingress #1)
SERVER_DOMAIN=app.example.com

# Public SSH hostname via Cloudflare (tunnel ingress #2)
SSH_DOMAIN=ssh.example.com

# cloudflared tunnel name (created once, reused on reruns)
TUNNEL_NAME=ai-maxx-ide

# Local port Django/uvicorn binds on (127.0.0.1 only)
LOCAL_SERVER_PORT=8000

# Windows username written into ~/.ssh/config for SSH_DOMAIN (optional)
SSH_USERNAME=

# true = install cloudflared Windows service after setup; false = skip
INSTALL_CLOUDFLARED_SERVICE=false

# true = skip creating a Flask smoke-test app.py in scripts/windows/
SKIP_FLASK_SMOKE_TEST=true

# true = skip OpenSSH Server install/start (use if sshd is already running)
SKIP_SSH_SETUP=false

# Optional extra tunnel hostnames as JSON list (hostname + service per entry).
# Appended after SERVER_DOMAIN and SSH_DOMAIN. Example:
# TUNNEL_EXTRA_INGRESS=[{"hostname":"grafana.example.com","service":"http://127.0.0.1:3000"}]
TUNNEL_EXTRA_INGRESS=[]

# --- Server (Django) — same .env file, used when server/ is implemented ---

CURSOR_API_KEY=
API_KEY=change-me-to-a-long-random-secret
DJANGO_SECRET_KEY=change-me-django-secret-key
REDIS_URL=redis://127.0.0.1:6379/0
DATABASE_URL=sqlite:///./data/db.sqlite3

# JSON array of absolute paths the server may expose as workspace roots
EXPOSED_DIRECTORIES_ABSOLUTE_PATHS=["C:/dev/project-a","D:/repos"]
